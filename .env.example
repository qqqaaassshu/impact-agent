IMPACT_AGENT_DATA_DIR=.impact-agent
IMPACT_AGENT_DEFAULT_INCLUDE=src
IMPACT_AGENT_DEFAULT_EXCLUDE=node_modules,dist,build,.git

CHAT_MODEL_PROVIDER=openai_compatible
CHAT_MODEL_NAME=deepseek-v4-flash
CHAT_MODEL_BASE_URL=https://api.deepseek.com
CHAT_MODEL_API_KEY=your_deepseek_api_key_here
CHAT_MODEL_RESPONSE_FORMAT=json_object
CHAT_MODEL_TEMPERATURE=0.2
CHAT_MODEL_MAX_TOKENS=4096

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL_NAME=bge-m3:latest
EMBEDDING_BASE_URL=http://127.0.0.1:11434
EMBEDDING_API_KEY=

MAX_REACT_ITERATION=8
MAX_TOOL_RESULTS=20
MAX_CHUNK_TOKENS=800
