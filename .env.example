# LLM 配置（必填）
# 推荐优先使用 OpenAI 兼容接口：国产大模型、企业网关、代理服务基本都可按这种方式接入。
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your_key_here
LLM_TEMPERATURE=0
LLM_STRUCTURED_MODE=json
# 默认关闭 LLM 扩词，使用确定性字段名变体以提升大项目速度。
LLM_CLUE_EXPANSION=false
# 默认关闭逐条语义复核，优先保证大项目扫描速度；需要更细判断时再开启。
LLM_SEMANTIC_REVIEW=false
# 对动态引用、变量传递等少量高风险上下文做批量 LLM 复核；LLM 只能判断已有 evidence，不能新增命中文件。
LLM_CONTEXT_REVIEW=true
# 特殊上下文复核上限，避免大仓库里 LLM 复核失控。
MAX_CONTEXT_REVIEW_ITEMS=20

# 也可以使用内置厂商别名，少写 LLM_BASE_URL：
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=your_key_here

# 常见国产 / 兼容服务示例：
# DeepSeek:
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
#
# 通义千问 / 阿里百炼:
# LLM_PROVIDER=qwen
# LLM_MODEL=qwen-plus
#
# 智谱 GLM:
# LLM_PROVIDER=zhipu
# LLM_MODEL=glm-4-flash
#
# Moonshot / Kimi:
# LLM_PROVIDER=moonshot
# LLM_MODEL=moonshot-v1-8k
#
# 火山方舟 / 豆包:
# LLM_PROVIDER=ark
# LLM_MODEL=你的方舟 endpoint id 或模型名
#
# 硅基流动:
# LLM_PROVIDER=siliconflow
# LLM_MODEL=Qwen/Qwen2.5-72B-Instruct
#
# 如果公司内部有统一大模型网关：
# LLM_MODEL=网关中的模型名
# LLM_BASE_URL=https://your-company-llm-gateway/v1
# LLM_API_KEY=your_key_here

# 结构化输出模式：
# json   ：默认，兼容性最好。通过普通对话要求模型返回 JSON，再由本地 Pydantic 校验。
# native ：使用模型服务原生 function calling / tool calling。只有确认服务支持时再开启。
# LLM_STRUCTURED_MODE=json
# LLM_CLUE_EXPANSION=false
# LLM_SEMANTIC_REVIEW=false
# LLM_CONTEXT_REVIEW=true
# MAX_CONTEXT_REVIEW_ITEMS=20

# Web / intake 默认项目配置：
# REPO_ROOT_PATH=/path/to/project
# REPO_PATH 可选；留空表示扫描工程根目录。大项目建议填写真实前端子目录以减少扫描耗时。
# REPO_PATH=
