# LLM 配置（必填），格式：provider:model_name

# 海外模型示例：
# LLM_MODEL=anthropic:claude-sonnet-4-20250514
# LLM_MODEL=openai:gpt-4o
# ANTHROPIC_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here

# 国内 OpenAI-compatible 模型示例（统一使用 LLM_API_KEY）：
# LLM_MODEL=deepseek:deepseek-chat
# LLM_MODEL=qwen:qwen-plus
# LLM_MODEL=zhipu:glm-4
# LLM_MODEL=moonshot:moonshot-v1-8k
# LLM_API_KEY=your_key_here

# 本地 Ollama 示例：
# LLM_MODEL=ollama:qwen2.5-coder:7b

# Web / intake 默认项目配置：
# REPO_ROOT_PATH=/path/to/project
# REPO_PATH=src
