# LLM configuration
# Prefer OpenAI-compatible chat APIs. Most domestic models, company gateways,
# and proxy services can be connected through MODEL + BASE_URL + API_KEY.

LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your_key_here
LLM_TEMPERATURE=0
LLM_STRUCTURED_MODE=json

# Performance defaults for large repositories.
# Keep clue expansion off by default; deterministic field-name variants are faster.
LLM_CLUE_EXPANSION=false

# Keep per-hit semantic review off by default; enable only when you need deeper checks.
LLM_SEMANTIC_REVIEW=false

# Review only selected high-risk uncertain contexts. The LLM can judge existing
# evidence, but it cannot add new hit files.
LLM_CONTEXT_REVIEW=true
MAX_CONTEXT_REVIEW_ITEMS=20

# Skill AST analysis. The TypeScript engine is used when Node + TypeScript are
# available; otherwise the Python structural fallback is used in auto mode.
AST_ANALYSIS_ENABLED=true
AST_ANALYSIS_ENGINE=auto
AST_ANALYSIS_TIMEOUT_SECONDS=3

# Provider aliases. You can use LLM_PROVIDER to avoid writing LLM_BASE_URL.
# DeepSeek:
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
#
# Qwen / Alibaba Bailian:
# LLM_PROVIDER=qwen
# LLM_MODEL=qwen-plus
#
# Zhipu GLM:
# LLM_PROVIDER=zhipu
# LLM_MODEL=glm-4-flash
#
# Moonshot / Kimi:
# LLM_PROVIDER=moonshot
# LLM_MODEL=moonshot-v1-8k
#
# Volcengine Ark / Doubao:
# LLM_PROVIDER=ark
# LLM_MODEL=your-ark-endpoint-id-or-model-name
#
# SiliconFlow:
# LLM_PROVIDER=siliconflow
# LLM_MODEL=Qwen/Qwen2.5-72B-Instruct

# Company internal gateway example:
# LLM_MODEL=your-company-model
# LLM_BASE_URL=https://your-company-llm-gateway/v1
# LLM_API_KEY=your_key_here
# LLM_STRUCTURED_MODE=json

# Structured output modes:
# json   : default and most compatible. The model returns JSON text and local
#          Pydantic validation checks it.
# native : use provider-native function calling / tool calling. Enable only
#          when the configured model service is confirmed to support it.
# LLM_STRUCTURED_MODE=json

# Web / intake default project settings:
# REPO_ROOT_PATH=D:\Wrok\product
# REPO_PATH is optional. Leave empty to scan the project root. For large
# repositories, prefer a real frontend subdirectory to reduce scan time.
# REPO_PATH=
